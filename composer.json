{
    "name": "thesis/endian",
    "description": "Library for encoding and decoding numbers in either big-endian or little-endian order.",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Valentin Udaltsov",
            "email": "udaltsov.valentin@gmail.com"
        },
        {
            "name": "kafkiansky",
            "email": "vadimzanfir@gmail.com"
        },
        {
            "name": "Thesis Team",
            "homepage": "https://github.com/orgs/thesisphp/people"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4",
        "symfony/var-dumper": "^8.0"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Thesis\\Endian\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Thesis\\Endian\\": "tests/"
        }
    },
    "config": {
        "lock": false,
        "sort-packages": true
    }
}
